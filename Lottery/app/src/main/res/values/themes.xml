<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Lottery" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOutline">@color/border_outline</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorSurfaceVariant">@color/page_background</item>
        <item name="colorSurfaceContainer">@color/page_background</item>
        <item name="colorSurfaceContainerLow">@color/page_background</item>
        <item name="colorSurfaceContainerHigh">@color/page_background</item>
        <item name="colorSurfaceContainerHighest">@color/page_background</item>
    </style>

    <style name="Theme.Lottery" parent="Base.Theme.Lottery" />
    <!-- Source: https://stackoverflow.com/a/57843956 -->
    <!-- Posted by Gabriele Mariotti -->
    <!-- Retrieved 2026-03-09, License: CC BY-SA 4.0 -->

    <style name="RoundedImageStyle">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ToolbarTitleAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_blue</item>
    <style name="App.Chip.Filter" parent="Widget.Material3.Chip.Filter">
      
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconVisible">false</item>
    </style>
</resources>
