<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Lottery" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOutline">@color/border_outline</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorSurfaceVariant">@color/page_background</item>
        <item name="colorSurfaceContainer">@color/page_background</item>
        <item name="colorSurfaceContainerLow">@color/page_background</item>
        <item name="colorSurfaceContainerHigh">@color/page_background</item>
        <item name="colorSurfaceContainerHighest">@color/page_background</item>

        <!-- Customize the image picker (MediaStore) and other system dialogs -->
        <item name="actionBarTheme">@style/ThemeOverlay.App.ActionBar</item>
        <item name="android:actionBarStyle">@style/Widget.App.ActionBar</item>

        <!-- Correct Material 3 Dialog Theme Mapping -->
        <item name="materialAlertDialogTheme">@style/App.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/App.MaterialAlertDialog</item>
    </style>

    <style name="Theme.Lottery" parent="Base.Theme.Lottery" />

    <style name="ThemeOverlay.App.ActionBar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="colorControlNormal">@color/primary_blue</item>
        <item name="android:textColorPrimary">@color/primary_blue</item>
    </style>

    <style name="Widget.App.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="titleTextStyle">@style/ToolbarTitleAppearance</item>
    </style>

    <style name="RoundedImageStyle">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="App.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="ToolbarTitleAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_blue</item>
    </style>

    <!-- Rounded Corner Material Alert Dialog with Blue/White Style -->
    <style name="App.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- 1. Round Corners (20dp) -->
        <item name="shapeAppearanceOverlay">@style/App.ShapeAppearance.Rounded</item>

        <!-- 2. Set primary action color to Blue -->
        <item name="colorPrimary">@color/primary_blue</item>

        <!-- 3. Make the list items (options) Blue -->
        <item name="android:textColorPrimary">@color/primary_blue</item>

        <!-- 4. Style the Title to be Blue and Bold -->
        <item name="materialAlertDialogTitleTextStyle">@style/App.Dialog.Title</item>
    </style>

    <style name="App.Dialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/primary_blue</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.ShapeAppearance.Rounded" parent="">
        <item name="cornerSize">20dp</item>
    </style>
</resources>
