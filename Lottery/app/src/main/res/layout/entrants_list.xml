<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/cancelled_entrants_list_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cancelled_entrants_list_header_text"
            android:textAlignment="center"
            android:textColor="@color/primary_blue"
            android:textSize="28sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/entrants_list_waited_list_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrants_list_toggle_button_group_waited_list_button_text"
                    android:textColor="@color/black"
                    app:cornerRadius="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/entrants_list_invited_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrants_list_toggle_button_group_invited_button_text"
                    android:textColor="@color/black"
                    app:cornerRadius="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/entrants_list_signed_up_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrants_list_toggle_button_group_signed_up_button_text"
                    android:textColor="@color/black"
                    app:cornerRadius="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/entrants_list_not_selected_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrants_list_toggle_button_group_not_selected_button_text"
                    android:textColor="@color/black"
                    app:cornerRadius="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/entrants_list_cancelled_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrants_list_toggle_button_group_cancelled_button_text"
                    android:textColor="@color/black"
                    app:cornerRadius="0dp" />

            </LinearLayout>
        </HorizontalScrollView>
        <!-- 2. Date and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/entrants_list_send_notification_btn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:layout_weight="0.33"
                android:backgroundTint="@color/accent_blue"
                android:text="@string/entrants_list_function_toggle_button_group_send_notification_text"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:cornerRadius="8dp"
                tools:ignore="RtlHardcoded" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/entrants_list_notify_selected_btn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:layout_weight="0.33"
                android:backgroundTint="@color/accent_blue"
                android:text="Notify Selected"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:cornerRadius="8dp"
                android:visibility="gone"
                tools:ignore="RtlHardcoded" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/entrants_list_view_location_btn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.33"
                android:backgroundTint="@color/accent_blue"
                android:text="@string/entrants_list_function_toggle_button_group_view_location_text"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:cornerRadius="8dp"
                tools:ignore="RtlHardcoded" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/entrants_list_export_csv_btn"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/accent_blue"
            android:text="Export Enrolled CSV"
            android:textColor="@color/white"
            app:cornerRadius="8dp" />

        <LinearLayout
            android:id="@+id/not_selected_entrants_list_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/not_selected_entrants_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                tools:itemCount="10"
                tools:listitem="@layout/entrant_list_item" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cancelled_entrants_list_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cancelled_entrants_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                tools:itemCount="10"
                tools:listitem="@layout/entrant_list_item" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/signed_up_entrants_list_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/signed_up_events_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                tools:listitem="@layout/entrant_list_item" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/invited_entrants_list_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/invited_events_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                tools:listitem="@layout/entrant_list_item" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/waited_list_entrants_list_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/waited_list_events_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:nestedScrollingEnabled="true"
                app:layout_constraintEnd_toStartOf="@+id/entrants_list_sample_button"
                tools:itemCount="8"
                tools:listitem="@layout/entrant_list_item" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/entrants_list_sample_btn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/entrants_list_sample_button"
                app:layout_constraintEnd_toEndOf="parent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/view_location_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/view_location_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/view_location_header_string"
                android:textAlignment="center"
                android:textColor="@color/primary_blue"
                android:textSize="28sp"
                android:textStyle="bold" />

            <com.google.android.gms.maps.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>