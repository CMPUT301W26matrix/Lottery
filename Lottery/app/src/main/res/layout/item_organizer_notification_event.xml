<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider_gray"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textColor="@color/primary_blue"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Date &amp; Time"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider_gray" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyWaiting"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@android:color/white"
            android:text="Notify Waiting List"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:cornerRadius="10dp"
            app:elevation="0dp"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifySelected"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/white"
            android:text="Notify Selected Entrants"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:cornerRadius="10dp"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyCancelled"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/white"
            android:text="Notify Cancelled Entrants"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            app:cornerRadius="10dp"
            app:elevation="0dp"
            app:strokeColor="@color/divider_gray"
            app:strokeWidth="1dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>