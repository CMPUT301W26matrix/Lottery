<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    tools:context=".AdminBrowseProfilesActivity">

    <!-- Header Bar: Page Title (Browse Profiles) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_header_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBrowseProfilesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/browse_profiles"
            android:textColor="@color/primary_blue"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnableDeleteProfile"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:paddingHorizontal="12dp"
            android:text="@string/enable_deletion"
            android:textColor="@color/error_red"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sub-header for Page Description (Shadow/Identity Strip) -->
    <LinearLayout
        android:id="@+id/layout_admin_identity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_light_blue"
        android:gravity="center"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse and manage user accounts in the system"
            android:textColor="@color/primary_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Role Filter Group (Segmented) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_filter_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:checkedButton="@+id/btnFilterAll"
        app:layout_constraintTop_toBottomOf="@id/layout_admin_identity"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterAll"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/all"
            android:textAllCaps="false"
            android:textColor="@color/chip_text_color"
            app:backgroundTint="@color/chip_background_color"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterEntrant"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/entrant"
            android:textAllCaps="false"
            android:textColor="@color/chip_text_color"
            app:backgroundTint="@color/chip_background_color"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterOrganizer"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/organizer"
            android:textAllCaps="false"
            android:textColor="@color/chip_text_color"
            app:backgroundTint="@color/chip_background_color"
            android:textSize="13sp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/tvEmptyProfiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/there_are_no_user_profiles_in_the_system"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toggle_filter_group"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/lvProfiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintTop_toBottomOf="@id/toggle_filter_group"
        tools:listitem="@android:layout/simple_list_item_2" />

    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include layout="@layout/layout_bottom_nav_admin" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
