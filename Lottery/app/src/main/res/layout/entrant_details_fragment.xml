<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/entrant_details_fragment"
    android:layout_height="match_parent"
    android:padding="12dp">
    <TextView
        android:id="@+id/details_fragment_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/entrant_details_header"
        android:textColor="@color/accent_blue"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <LinearLayout
        android:id="@+id/details_fragment_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAME"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_id"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="ID"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Id"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_registration_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_id"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/registration_time"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_registration_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REG TIME"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_location"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_registration_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_invited_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_location"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Invited Time"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_invited_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_cancelled_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_invited_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Cancelled Time"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_cancelled_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelled Time"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/details_fragment_signed_up_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/details_fragment_cancelled_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Signed Up Time"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/details_signed_up_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Signed Up Time"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>